# ─────────────────────────────────────────────────────────────
# Catalog Insights — environment configuration
# Copy to .env and fill in. Nothing here is secret by default;
# treat PDC_PASSWORD and any commercial API keys as secrets.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
INSIGHTS_HOST=0.0.0.0
# Host port for the web app's container mapping. Default 8660 — chosen to clear
# Pentaho/Tomcat and PDC ports. AVOID these (commonly in use on a PDC/Pentaho box):
#   8080 Tomcat/PUC · 8090 Pentaho config (AWS/K8s) · 8443/9443 SSL · 8009 AJP
#   8005 shutdown · 9200 OpenSearch · 27017 MongoDB · 11434 Ollama · 8765 this MCP
#   5000 Glossary Generator · 5001 Policy Generator (sibling apps on the demo host)
# Change this if 8660 is taken; the container always listens on 8660 internally.
INSIGHTS_PORT=8660
INSIGHTS_LOG_LEVEL=INFO

# ── Branding (genericise the product, same pattern as the
#    Glossary Generator's GLOSSARY_* vars) ────────────────────
INSIGHTS_BRAND_NAME=Catalog Insights
INSIGHTS_BRAND_PRODUCT=Pentaho Data Catalog
INSIGHTS_BRAND_ACCENT=#0F766E

# ── PDC connection ───────────────────────────────────────────
PDC_BASE_URL=https://pdc.example.local
PDC_API_VERSION=v3
PDC_USERNAME=pdc_user
PDC_PASSWORD=catalog123!
# Auth strategy. PDC delegates auth to Keycloak (OIDC):
#   auto     = try Keycloak token endpoint, fall back to /api/public/<v>/auth (default)
#   keycloak = Keycloak realm token endpoint only (most reliable)
#   pdc      = legacy /api/public/<v>/auth wrapper only
# If you saw "Auth returned 200 but no accessToken", that's the legacy wrapper;
# auto/keycloak route around it.
PDC_AUTH_METHOD=auto
PDC_KC_REALM=pdc
PDC_KC_CLIENT_ID=pdc-client
# Optional: explicit Keycloak base (defaults to {PDC_BASE_URL}/keycloak).
PDC_KC_BASE=
# If PDC is behind a Cloudflare tunnel with Access/Bot-Fight enabled, an API
# client gets an HTML challenge instead of JSON (a browser passes it; requests
# can't). Create a Cloudflare Access service token and set both values; they're
# sent on every PDC + Keycloak call. (Alternatively, point PDC_BASE_URL/
# PDC_KC_BASE at an internal address that bypasses Cloudflare.)
PDC_CF_ACCESS_CLIENT_ID=
PDC_CF_ACCESS_CLIENT_SECRET=
# Optional: pin a bearer token instead of user/pass. Note: this DISABLES the
# automatic 401 re-auth, so the token will expire — prefer user/pass for a
# running service; use this only for quick tests. (Token = Keycloak access_token,
# or data.accessToken from the legacy POST /api/public/{version}/auth.)
PDC_BEARER_TOKEN=
PDC_VERIFY_TLS=true
# Cache facet/search responses for this many seconds (0 disables)
PDC_CACHE_TTL=300

# ── LLM provider ─────────────────────────────────────────────
# provider = local | anthropic | openai | disabled
LLM_PROVIDER=local
# Model to pull/use. GPU default is 7B; on CPU prefer a smaller model.
# Run  python tools/suggest_model.py  to get a recommendation for THIS host.
LLM_MODEL=qwen2.5:7b-instruct
# Native (Ollama on this host, app run directly): use localhost.
# Running the app via docker compose? The compose file overrides this with
# host.docker.internal automatically — you don't need to change anything.
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=
# Force valid JSON out of weaker local models (Ollama supports this)
LLM_JSON_MODE=true
LLM_TIMEOUT=120
# Hard ceiling so a runaway prompt can't drain a metered account
LLM_MAX_TOKENS=4000

# ── Security ─────────────────────────────────────────────────
# Auth mode for BOTH the web app and the MCP server: none | apikey | jwt
#   none   — open (local/dev only); callers assume INSIGHTS_DEFAULT_ROLE
#   apikey — bearer token looked up in INSIGHTS_API_KEYS
#   jwt    — bearer JWT validated via shared secret or JWKS
INSIGHTS_AUTH=none
# Role assumed when INSIGHTS_AUTH=none. Set to viewer to be safe; admin eases dev.
INSIGHTS_DEFAULT_ROLE=admin

# apikey mode: comma-separated  key:name:role  (roles: viewer|steward|admin)
INSIGHTS_API_KEYS=

# jwt mode: provide EITHER a shared secret OR a JWKS URL
INSIGHTS_JWT_SECRET=
INSIGHTS_JWT_JWKS_URL=
INSIGHTS_JWT_AUDIENCE=
INSIGHTS_JWT_ISSUER=
# Which claim holds the role, and how to map external role names to ours
INSIGHTS_JWT_ROLE_CLAIM=role
INSIGHTS_JWT_ROLE_MAP=Data Steward:steward,Administrator:admin,Analyst:viewer

# MCP transport-auth metadata (only used when INSIGHTS_AUTH != none)
INSIGHTS_AUTH_ISSUER=https://catalog-insights.local
INSIGHTS_MCP_URL=http://localhost:8765

# Append-only audit log of privileged actions (blank = stderr only)
INSIGHTS_AUDIT_LOG=

# Demo mode: serve a bundled sample catalog so the app/MCP run without a live
# PDC. Great for enablement; turn off in real deployments.
INSIGHTS_DEMO=false
